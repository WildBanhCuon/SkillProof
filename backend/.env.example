# Local Docker (see docker-compose.yml)
DATABASE_URL=postgresql://skillproof:skillproof@127.0.0.1:54333/skillproof?schema=public

# Render Postgres (same region as API): use Internal URL from dashboard, then append sslmode if missing:
# DATABASE_URL=postgresql://USER:PASS@HOST/DATABASE?sslmode=require

REDIS_URL=redis://localhost:6379
# Render Key Value: use Internal Redis URL, e.g. redis://red-xxxxxxxx:6379
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
